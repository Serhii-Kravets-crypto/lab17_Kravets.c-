#include <iostream>
#include <cmath>
using namespace std;
#include "windows.h"

class Vector3D
{
protected:

	double x1, y1, z1;
	double x2, y2, z2;

public:

	void set(double startX, double startY, double startZ, double endX, double endY, double endZ)
	{
		x1 = startX;
		y1 = startY;
		z1 = startZ;
		x2 = endX;
		y2 = endY;
		z2 = endZ;
	}

	double getX1() { return x1; }
	double getY1() { return y1; }
	double getZ1() { return z1; }
	double getX2() { return x2; }
	double getY2() { return y2; }
	double getZ2() { return z2; }

	double getDx() { return x2 - x1; }
	double getDy() { return y2 - y1; }
	double getDz() { return z2 - z1; }

	void print()
	{
		cout << "Координати початку: (" << x1 << ", " << y1 << ", " << z1 << ")" << endl;
		cout << "Координати кінця: (" << x2 << ", " << y2 << ", " << z2 << ")" << endl;
		cout << "Проекції вектора: {" << getDx() << ", " << getDy() << ", " << getDz() << "}" << endl;
	}
};

class ExtendedVector3D : public Vector3D
{
public:

	double getLength()
	{
		double dx = getDx();
		double dy = getDy();
		double dz = getDz();
		return sqrt(dx * dx + dy * dy + dz * dz);
	}

	double scalarProduct(ExtendedVector3D& other)
	{
		return (getDx() * other.getDx() + getDy() * other.getDy() + getDz() * other.getDz());
	}

	double cosineAngle(ExtendedVector3D& other)
	{
		double len1 = getLength();
		double len2 = other.getLength();

		if (len1 == 0 || len2 == 0)
		{
			cout << "Помилка: неможливо обчислити кут з нульовим вектором!" << endl;
			return 0;
		}

		return scalarProduct(other) / (len1 * len2);
	}
};

